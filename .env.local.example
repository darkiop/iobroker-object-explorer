# Dev server config — copy to .env.local and set your ioBroker REST API address.
# This is the only place you need to configure for local development.
VITE_IOBROKER_TARGET=http://10.4.0.33:8093
# Comma-separated hostnames allowed by the Vite dev server (CORS/host check).
VITE_ALLOWED_HOSTS=pve-ct-dev,localhost,127.0.0.1,your-domain.example.com
